---
import { friendLinkCatalog } from "../data/friend-links";
const links = friendLinkCatalog.items;
---

<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-4">
  {links.map((link) => (
    <a
      href={(() => { const a = link.action; return a.type === "openUrl" && a.url ? a.url : "#"; })()}
      target="_blank"
      rel="noopener noreferrer"
      class="flex flex-col items-center gap-2 p-4 rounded-[var(--md-sys-shape-corner-small)] hover:bg-[var(--md-sys-color-surface-container-high)] dark:hover:bg-[var(--md-sys-color-surface-container-high-dark)] transition-colors no-underline"
    >
      {link.image && <img src={link.image.url} alt={link.title} class="w-12 h-12 rounded-full object-cover" loading="lazy" />}
      <span class="text-[var(--md-sys-typescale-body-small-size)] font-[var(--md-sys-typescale-label-large-weight)] text-[var(--md-sys-color-on-surface-variant)]">{link.title}</span>
    </a>
  ))}
</div>
