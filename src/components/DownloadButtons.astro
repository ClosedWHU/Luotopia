---
export interface Props {
  variant?: "hero" | "default";
}

const { variant = "default" } = Astro.props;
---

<div class="flex flex-wrap justify-center gap-3">
  <a
    href="/download"
    class="state-layer inline-flex items-center gap-2 rounded-[var(--md-sys-shape-corner-full)] px-6 py-2.5 bg-[var(--md-sys-color-primary)] text-[var(--md-sys-color-on-primary)] text-[var(--md-sys-typescale-label-large-size)] font-[var(--md-sys-typescale-label-large-weight)] no-underline shadow-[var(--md-sys-elevation-level1)] hover:shadow-[var(--md-sys-elevation-level2)] transition-shadow"
  >
    <span class="material-symbols-outlined text-lg">download</span>
    下载 App
  </a>
  <a
    href="/features"
    class="state-layer inline-flex items-center gap-2 rounded-[var(--md-sys-shape-corner-full)] px-6 py-2.5 bg-transparent text-[var(--md-sys-color-primary)] text-[var(--md-sys-typescale-label-large-size)] font-[var(--md-sys-typescale-label-large-weight)] no-underline border border-[var(--md-sys-color-outline)] transition-shadow"
  >
    了解功能
  </a>
</div>
