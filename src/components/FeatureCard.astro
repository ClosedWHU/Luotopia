---
export interface Props {
  icon: string;
  title: string;
  description: string;
}

const { icon, title, description } = Astro.props;
---

<div class="rounded-card bg-surface-card dark:bg-surface-card-dark p-6 hover:bg-surface-hover dark:hover:bg-surface-hover-dark transition-colors">
  <div class="text-2xl mb-3 text-luotopia-500 dark:text-luotopia-300">{icon}</div>
  <h3 class="text-lg font-semibold text-gray-800 dark:text-gray-100 mb-2">{title}</h3>
  <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">{description}</p>
</div>
