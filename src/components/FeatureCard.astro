---
export interface Props {
  icon: string;
  title: string;
  description: string;
}

const { icon, title, description } = Astro.props;
---

<div class="state-layer rounded-[var(--md-sys-shape-corner-medium)] bg-[var(--md-sys-color-surface-container-low)] dark:bg-[var(--md-sys-color-surface-container-low-dark)] p-5 transition-shadow hover:shadow-[var(--md-sys-elevation-level2)] shadow-[var(--md-sys-elevation-level0)]">
  <span class="material-symbols-outlined text-[var(--md-sys-color-primary)] text-2xl mb-3 block">{icon}</span>
  <h3 class="text-[var(--md-sys-typescale-title-medium-size)] leading-[var(--md-sys-typescale-title-medium-line)] font-[var(--md-sys-typescale-title-medium-weight)] text-[var(--md-sys-color-on-surface)] mb-1.5">{title}</h3>
  <p class="text-[var(--md-sys-typescale-body-medium-size)] leading-[var(--md-sys-typescale-body-medium-line)] text-[var(--md-sys-color-on-surface-variant)]">{description}</p>
</div>
