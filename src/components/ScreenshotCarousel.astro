---
const slides = [
  { label: "课程表", src: "/img/screenshots/schedule.png" },
  { label: "校园应用", src: "/img/screenshots/campus.png" },
  { label: "AI 助手", src: "/img/screenshots/ai-assistant.png" },
  { label: "天气详情", src: "/img/screenshots/weather-detail.png" },
  { label: "空气质量", src: "/img/screenshots/weather-aqi.png" },
  { label: "校车", src: "/img/screenshots/bus.png" },
  { label: "壁纸中心", src: "/img/screenshots/wallpaper.png" },
];
---

<div class="relative overflow-hidden rounded-[var(--md-sys-shape-corner-medium)] bg-[var(--md-sys-color-surface-container-low)] pb-8 dark:bg-[var(--md-sys-color-surface-container-low-dark)]">
  <div id="carousel-track" class="flex transition-transform duration-500 ease-out">
    {slides.map((slide, i) => (
      <div class="shrink-0 w-full sm:w-1/2 lg:w-1/4 p-1.5">
        <figure class="overflow-hidden rounded-[var(--md-sys-shape-corner-medium)] bg-[var(--md-sys-color-surface-container)] dark:bg-[var(--md-sys-color-surface-container-dark)] shadow-[var(--md-sys-elevation-level1)]">
          <img
            src={slide.src}
            alt={slide.label}
            width="360"
            height="780"
            loading={i < 2 ? "eager" : "lazy"}
            decoding="async"
            class="w-full h-auto object-cover object-center aspect-[9/16] max-h-[500px]"
          />
          <figcaption class="px-3 py-2 text-center text-[length:var(--md-sys-typescale-label-large-size)] font-[var(--md-sys-typescale-label-large-weight)] text-[var(--md-sys-color-on-surface-variant)]">
            {slide.label}
          </figcaption>
        </figure>
      </div>
    ))}
  </div>

  <button id="carousel-prev" class="absolute left-2 top-1/2 -translate-y-1/2 p-2 rounded-full bg-[var(--md-sys-color-surface-container-high)] dark:bg-[var(--md-sys-color-surface-container-high-dark)] text-[var(--md-sys-color-on-surface-variant)] hover:text-[var(--md-sys-color-primary)] transition-colors cursor-pointer shadow-[var(--md-sys-elevation-level2)]" aria-label="上一张">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
  </button>
  <button id="carousel-next" class="absolute right-2 top-1/2 -translate-y-1/2 p-2 rounded-full bg-[var(--md-sys-color-surface-container-high)] dark:bg-[var(--md-sys-color-surface-container-high-dark)] text-[var(--md-sys-color-on-surface-variant)] hover:text-[var(--md-sys-color-primary)] transition-colors cursor-pointer shadow-[var(--md-sys-elevation-level2)]" aria-label="下一张">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
  </button>

  <div class="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-1.5">
    {slides.map((_, i) => (
      <button class="carousel-dot w-2 h-2 rounded-full bg-[var(--md-sys-color-outline)] transition-all cursor-pointer data-[active=true]:w-4 data-[active=true]:bg-[var(--md-sys-color-primary)]" data-index={i} aria-label={`第 ${i + 1} 张截图`}></button>
    ))}
  </div>
</div>

<script>
  (function () {
    const track = document.getElementById("carousel-track");
    const prev = document.getElementById("carousel-prev");
    const next = document.getElementById("carousel-next");
    const dots = document.querySelectorAll(".carousel-dot");
    if (!track || !prev || !next) return;

    const total = dots.length;
    let current = 0;

    function getCols() {
      if (window.innerWidth < 640) return 1;
      if (window.innerWidth < 1024) return 2;
      return 4;
    }

    function update() {
      const cols = getCols();
      const max = Math.max(0, total - cols);
      if (current > max) current = max;
      const pct = 100 / cols;
      track.style.transform = `translateX(-${current * pct}%)`;
      dots.forEach((dot, i) => { dot.dataset.active = String(i >= current && i < current + cols); });
    }

    prev.addEventListener("click", () => { current = Math.max(0, current - 1); update(); });
    next.addEventListener("click", () => {
      const cols = getCols();
      const max = Math.max(0, total - cols);
      current = Math.min(max, current + 1);
      update();
    });
    dots.forEach((dot) => {
      dot.addEventListener("click", () => {
        current = Math.min(parseInt(dot.dataset.index ?? "0"), Math.max(0, total - getCols()));
        update();
      });
    });

    let resizeTimer;
    window.addEventListener("resize", () => { clearTimeout(resizeTimer); resizeTimer = setTimeout(update, 100); });

    let autoplay = setInterval(() => {
      const cols = getCols();
      const max = Math.max(0, total - cols);
      current = current >= max ? 0 : current + 1;
      update();
    }, 5000);
    const container = track.parentElement;
    container?.addEventListener("mouseenter", () => clearInterval(autoplay));
    container?.addEventListener("mouseleave", () => {
      autoplay = setInterval(() => {
        const cols = getCols();
        const max = Math.max(0, total - cols);
        current = current >= max ? 0 : current + 1;
        update();
      }, 5000);
    });
  })();
</script>
