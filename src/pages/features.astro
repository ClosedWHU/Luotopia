---
import BaseLayout from "../layouts/BaseLayout.astro";
import FeatureCard from "../components/FeatureCard.astro";

const categories = [
  {
    title: "校园服务",
    items: [
      { icon: "calendar_month", title: "课程表", description: "对接武大教务系统导入课程数据，支持 WakeUp 导入与本地编辑，多课表管理，周月视图灵活切换。" },
      { icon: "school", title: "空闲教室", description: "按日期、校区、楼栋、节次多维查询空闲教室，支持生成日程事项，全状态处理覆盖所有查询场景。" },
      { icon: "library_books", title: "图书馆座位预约", description: "空间、日期、时段、座位自由筛选，创建与取消预约，管理我的预约列表。" },
      { icon: "sports_tennis", title: "运动场馆预约", description: "场馆、项目、时段一站式预约，支持预约取消与订单查看，可加入日程提醒。" },
      { icon: "credit_card", title: "珞珈E卡与付款码", description: "双入口 WebView，完美处理 CAS Cookie 与智能校园 UA 权限，校园支付便捷安全。" },
      { icon: "directions_bus", title: "校车", description: "校车线路查询与实时位置追踪，告别盲目等待。" },
      { icon: "calendar_view_day", title: "校历", description: "武大校历数据展示，学期安排一目了然。" },
      { icon: "bar_chart", title: "学业状态", description: "培养方案与修读进度等教务侧学业信息全面展示。" },
      { icon: "edit_note", title: "成绩查询", description: "教务导入、GPA 算法切换、防剧透模式、学期分组与学业摘要。" },
    ],
  },
  {
    title: "智能工具",
    items: [
      { icon: "smart_toy", title: "AI 助手", description: "智能会话管理，支持事项查询与创建，多会话切换与持久化，让校园生活更高效。" },
      { icon: "partly_cloudy_day", title: "天气", description: "直连 OpenMeteo / 小米天气 / AccuWeather 多数据源，逐小时预报、AQI 与预警，支持缓存与重试。" },
      { icon: "palette", title: "壁纸中心", description: "无壁纸 / 本地图片 / Bing 每日随机，多个页面独立配置，个性化你的校园应用。" },
    ],
  },
  {
    title: "开发中",
    items: [
      { icon: "menu_book", title: "图书借阅", description: "接入馆藏借阅 API，展示当前借阅、到期时间、续借状态，支持到期提醒。即将上线。" },
      { icon: "forum", title: "论坛：珞珈防空洞", description: "帖子、评论、版块管理，完整的社区讨论平台。服务端已就绪，客户端筹备中。" },
      { icon: "star", title: "课程给分与评价", description: "按课程查看给分统计，匿名提交与评价，与 whu.sb 历史数据兼容。开发中。" },
      { icon: "folder", title: "学习资料共享", description: "按课程、教师、学期检索资料，支持上传下载与收藏。服务端已就绪。" },
    ],
  },
];
---

<BaseLayout title="功能">
  <section class="pt-28 pb-16 px-4">
    <div class="max-w-6xl mx-auto">
      <h1 class="text-[var(--md-sys-typescale-headline-medium-size)] leading-[var(--md-sys-typescale-headline-medium-line)] font-[var(--md-sys-typescale-headline-medium-weight)] text-[var(--md-sys-color-on-surface)] mb-2">功能全览</h1>
      <p class="text-[var(--md-sys-typescale-body-large-size)] text-[var(--md-sys-color-on-surface-variant)] mb-12">Luotopia 为你提供丰富的校园数字化服务</p>

      {categories.map((cat) => (
        <div class="mb-14">
          <h2 class="text-[var(--md-sys-typescale-title-medium-size)] leading-[var(--md-sys-typescale-title-medium-line)] font-[var(--md-sys-typescale-title-medium-weight)] text-[var(--md-sys-color-on-surface)] mb-6 flex items-center gap-2">
            <span class="w-1 h-5 rounded-full bg-[var(--md-sys-color-primary)] inline-block"></span>
            {cat.title}
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {cat.items.map((f) => <FeatureCard {...f} />)}
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
